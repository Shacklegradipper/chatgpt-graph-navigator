{
  "name": "chatgpt-graph-extension",
  "version": "0.1.0",
  "description": "Visualize ChatGPT conversations as navigable knowledge graphs in a Chrome extension.",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "build:release": "node build.js --release",
    "dev": "npm run build:watch",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,html}\""
  },
  "keywords": [
    "chatgpt",
    "chrome-extension",
    "graph",
    "visualization"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@xyflow/react": "^12.0.0",
    "dagre": "^0.8.5"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
