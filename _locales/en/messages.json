  "setupTitle": {
    "message": "ChatGPT Graph Navigator"
  },
  "setupSubtitle": {
    "message": "Setup - Get Your Authentication Token"
  },
  "step1Title": {
    "message": "Open ChatGPT and Login"
  },
  "step1Content": {
    "message": "Go to <strong>https://chatgpt.com</strong> and make sure you are logged into your account."
  },
  "step2Title": {
    "message": "Open Developer Tools"
  },
  "step2Content": {
    "message": "On the ChatGPT page, press:"
  },
  "step2Windows": {
    "message": "<strong>Windows/Linux:</strong> F12 or Ctrl + Shift + I"
  },
  "step2Mac": {
    "message": "<strong>Mac:</strong> Cmd + Option + I"
  },
  "step2Footer": {
    "message": "The Developer Tools will open at the bottom or side of the page."
  },
  "step3Title": {
    "message": "Switch to Network Tab"
  },
  "step3Content": {
    "message": "At the top of Developer Tools, click the <strong>Network</strong> tab."
  },
  "step4Title": {
    "message": "Trigger API Request"
  },
  "step4Content": {
    "message": "Send a message in ChatGPT (any content works), or refresh the page (F5).<br>This will trigger an API request from which we can get the token."
  },
  "step5Title": {
    "message": "Find backend-api Request"
  },
  "step5Content": {
    "message": "In the Network tab's request list, find any request starting with <code>backend-api</code>, such as:"
  },
  "step5Examples": {
    "message": "backend-api/conversation<br>backend-api/conversations<br>backend-api/me"
  },
  "step5Footer": {
    "message": "Click on that request."
  },
  "step6Title": {
    "message": "Copy Authorization Token"
  },
  "step6Item1": {
    "message": "In the right panel, click the <strong>Headers</strong> tab"
  },
  "step6Item2": {
    "message": "Scroll down to find the <strong>Request Headers</strong> section"
  },
  "step6Item3": {
    "message": "Find the <strong>authorization:</strong> line"
  },
  "step6Item4": {
    "message": "Its value is in the format <code>Bearer eyJhbGci...</code>"
  },
  "step6Item5": {
    "message": "<strong>Only copy the part after Bearer</strong> (do not include the word Bearer)"
  },
  "step6Footer": {
    "message": "The token is usually very long (1000+ characters) and starts with <code>eyJ</code>."
  },
  "step7Title": {
    "message": "Paste Token"
  },
  "step7Label": {
    "message": "Paste your Access Token:"
  },
  "step7Placeholder": {
    "message": "eyJhbGciOiJSUzI1NiIsImtpZCI6IjE5MzQ0ZTY1LWJiYzktNDRkMS1hOWQwLWY5NTdi..."
  },
