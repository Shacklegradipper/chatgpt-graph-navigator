  "setupTitle": {
    "message": "ChatGPT Graph Navigator"
  },
  "setupSubtitle": {
    "message": "设置 - 获取您的认证令牌"
  },
  "step1Title": {
    "message": "打开 ChatGPT 并登录"
  },
  "step1Content": {
    "message": "前往 <strong>https://chatgpt.com</strong> 并确保你已经登录你的账号。"
  },
  "step2Title": {
    "message": "打开开发者工具"
  },
  "step2Content": {
    "message": "在 ChatGPT 页面上，按下键盘上的："
  },
  "step2Windows": {
    "message": "<strong>Windows/Linux:</strong> F12 或 Ctrl + Shift + I"
  },
  "step2Mac": {
    "message": "<strong>Mac:</strong> Cmd + Option + I"
  },
  "step2Footer": {
    "message": "开发者工具会在页面底部或右侧打开。"
  },
  "step3Title": {
    "message": "切换到 Network 标签页"
  },
  "step3Content": {
    "message": "在开发者工具的顶部，点击 <strong>Network</strong> (网络) 标签页。"
  },
  "step4Title": {
    "message": "触发 API 请求"
  },
  "step4Content": {
    "message": "在 ChatGPT 中发送一条消息（任何内容都可以），或者刷新页面 (F5)。<br>这会触发 API 请求，我们可以从中获取 token。"
  },
  "step5Title": {
    "message": "查找 backend-api 请求"
  },
  "step5Content": {
    "message": "在 Network 标签页的请求列表中，找到任何以 <code>backend-api</code> 开头的请求，例如："
  },
  "step5Examples": {
    "message": "backend-api/conversation<br>backend-api/conversations<br>backend-api/me"
  },
  "step5Footer": {
    "message": "点击该请求。"
  },
  "step6Title": {
    "message": "复制 Authorization Token"
  },
  "step6Item1": {
    "message": "在右侧面板中，点击 <strong>Headers</strong> (请求头) 标签页"
  },
  "step6Item2": {
    "message": "向下滚动找到 <strong>Request Headers</strong> (请求标头) 部分"
  },
  "step6Item3": {
    "message": "找到 <strong>authorization:</strong> 这一行"
  },
  "step6Item4": {
    "message": "它的值是 <code>Bearer eyJhbGci...</code> 这样的格式"
  },
  "step6Item5": {
    "message": "<strong>只复制 Bearer 后面的部分</strong>（不包括 Bearer 这个词）"
  },
  "step6Footer": {
    "message": "Token 通常很长（1000+ 字符），以 <code>eyJ</code> 开头。"
  },
  "step7Title": {
    "message": "粘贴 Token"
  },
  "step7Label": {
    "message": "粘贴你的 Access Token:"
  },
  "step7Placeholder": {
    "message": "eyJhbGciOiJSUzI1NiIsImtpZCI6IjE5MzQ0ZTY1LWJiYzktNDRkMS1hOWQwLWY5NTdi..."
  },
